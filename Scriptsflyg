local function tweenTileColor(tile, isPressed) 
	local themeColor = matchOverlayColor and currentMenuColor or accentColor 
	local targetColor = isPressed and themeColor or Color3.fromRGB(30, 30, 30) 
	local targetTextSize = isPressed and (8 * keysScale) or (12 * keysScale) 
	if tile.Name == "Space" then 
		targetTextSize = 8 * keysScale 
	end 
	TweenService:Create(tile, TweenInfo.new(0.1), { BackgroundColor3 = targetColor, TextSize = targetTextSize }):Play() 
end 

