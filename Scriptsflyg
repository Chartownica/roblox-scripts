local function updatePlayerList() 
	for _, child in pairs(tpContainer:GetChildren()) do 
		if child:IsA("TextButton") then 
			child:Destroy() 
		end 
	end 
	local count = 0 
	for _, p in pairs(Players:GetPlayers()) do 
		if p ~= player then 
			count = count + 1 
			local pBtn = Instance.new("TextButton") 
			pBtn.Size = UDim2.new(1, -4, 0, 24) 
			pBtn.Text = p.DisplayName .. " (@" .. p.Name .. ")" 
			pBtn.TextColor3 = Color3.fromRGB(240, 240, 240) 
			pBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45) 
			pBtn.TextSize = 11 
			pBtn.Parent = tpContainer 
			Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 4) 
			pBtn.MouseEnter:Connect(function() 
				pBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60) 
			end) 
			pBtn.MouseLeave:Connect(function() 
				pBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45) 
			end) 
			pBtn.MouseButton1Click:Connect(function() 
				if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and rootPart then 
					local wasFlying = isFlying 
					if isFlying then stopFlying() end 
					rootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 2, 0) 
					if wasFlying then 
						task.wait(0.1) 
						startFlying() 
					end 
				end 
			end) 
		end 
	end 
	tpContainer.CanvasSize = UDim2.new(0, 0, 0, count * 28) 
end 

