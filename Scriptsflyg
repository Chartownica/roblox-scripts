-------------------------------------------- 
local flySpeed = 50 
local bodyVelocity = nil 
local bodyGyro = nil 
local moveDirection = Vector3.new(0, 0, 0) 
local NoclipConnection = nil 

function startFlying() 
	if not isFlying and rootPart and humanoid then 
		isFlying = true 
		flyButton.Text = "Fly: ON [" .. flyKey.Name .. "]" 
		updateUIColors() 
		humanoid.PlatformStand = true 
		humanoid.WalkSpeed = 0 
		bodyVelocity = Instance.new("BodyVelocity") 
		bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge) 
		bodyVelocity.Velocity = Vector3.new(0, 0, 0) 
		bodyVelocity.Parent = rootPart 
		bodyGyro = Instance.new("BodyGyro") 
		bodyGyro.MaxTorque = Vector3.new(4000, 4000, 4000) 
		bodyGyro.CFrame = camera.CFrame 
		bodyGyro.Parent = rootPart 
	end 
end 

function stopFlying() 
	if isFlying then 
		isFlying = false 
		flyButton.Text = "Fly: OFF [" .. flyKey.Name .. "]" 
		updateUIColors() 
		if humanoid then 
			humanoid.PlatformStand = false 
			humanoid.WalkSpeed = 16 
		end 
		if bodyVelocity then 
			bodyVelocity:Destroy() 
			bodyVelocity = nil 
		end 
		if bodyGyro then 
			bodyGyro:Destroy() 
			bodyGyro = nil 
		end 
	end 
end 

local function toggleFly() 
	if isFlying then 
		stopFlying() 
	else 
		startFlying() 
	end 
end 

local function noclipLoop() 
	if Clip == false and character then 
		for _, v in pairs(character:GetDescendants()) do 
			if v:IsA('BasePart') and v.CanCollide then 
				v.CanCollide = false 
			end 
		end 
	end 
end 

local function startNoclip() 
	Clip = false 
	noClipButton.Text = "No-Clip: ON [" .. noclipKey.Name .. "]" 
	updateUIColors() 
	NoclipConnection = RunService.Stepped:Connect(noclipLoop) 
end 

local function stopNoclip() 
	Clip = true 
	if NoclipConnection then 
		NoclipConnection:Disconnect() 
	end 
	noClipButton.Text = "No-Clip: OFF [" .. noclipKey.Name .. "]" 
	updateUIColors() 
	if character then 
		for _, v in pairs(character:GetDescendants()) do 
			if v:IsA('BasePart') then 
				v.CanCollide = true 
			end 
		end 
		if rootPart then 
			rootPart.CFrame = rootPart.CFrame * CFrame.new(0, 0.1, 0) 
		end 
	end 
end 

local function toggleNoClip() 
	if Clip then 
		startNoclip() 
	else 
		stopNoclip() 
	end 
end 

flyButton.MouseButton1Click:Connect(toggleFly) 
noClipButton.MouseButton1Click:Connect(toggleNoClip) 

