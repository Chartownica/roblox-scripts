local cpDragging = false
local function updateColorFromPicker(input)
    local cpSize = colorPickerFrame.AbsoluteSize
    local cpPos = colorPickerFrame.AbsolutePosition
    local inputPos = input.Position

    local relativeX = math.clamp((inputPos.X - cpPos.X) / cpSize.X, 0, 1)
    local relativeY = math.clamp((inputPos.Y - cpPos.Y) / cpSize.Y, 0, 1)

    pickerSelection.Position = UDim2.new(relativeX, 0, relativeY, 0)

    local hue = relativeX
    local sat = 1 - (relativeY * 0.7)
    local val = 0.2 + ((1 - relativeY) * 0.4)
    
    currentMenuColor = Color3.fromHSV(hue, sat, val)
    updateUIColors()
end

colorPickerFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        cpDragging = true
        updateColorFromPicker(input)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if cpDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateColorFromPicker(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then cpDragging = false end
end)


