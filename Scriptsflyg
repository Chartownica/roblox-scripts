-- TRAIL AND JUMP CIRCLE LOGIC
-------------------------------------------- 
local currentTrail = nil
local jumpConnections = {}

local function createTrail()
	if currentTrail then currentTrail:Destroy() end
	if not character or not rootPart then return end
	
	local trailAttachment0 = Instance.new("Attachment")
	trailAttachment0.Position = Vector3.new(0, -2, 0)
	trailAttachment0.Parent = rootPart
	
	local trailAttachment1 = Instance.new("Attachment")
	trailAttachment1.Position = Vector3.new(0, 2, 0)
	trailAttachment1.Parent = rootPart
	
	local trail = Instance.new("Trail")
	trail.Color = ColorSequence.new(trailColor)
	trail.LightEmission = 0.5
	trail.Transparency = NumberSequence.new(0.3)
	trail.Lifetime = 1.5
	trail.Attachment0 = trailAttachment0
	trail.Attachment1 = trailAttachment1
	trail.Parent = rootPart
	
	currentTrail = trail
	return trail
end

local function updateTrail()
	if trailEnabled then
		createTrail()
	else
		if currentTrail then
			currentTrail:Destroy()
			currentTrail = nil
		end
	end
end

local function createJumpCircle(pos)
	if not jumpCircleEnabled then return end
	
	local circle = Instance.new("Part")
	circle.Size = Vector3.new(6, 0.2, 6)
	circle.Shape = Enum.PartType.Cylinder
	circle.Position = pos + Vector3.new(0, 0.1, 0)
	circle.Rotation = Vector3.new(90, 0, 0)
	circle.Anchored = true
	circle.CanCollide = false
	circle.Transparency = 0.3
	circle.Color = jumpCircleColor
	circle.Material = Enum.Material.Neon
	circle.Parent = workspace
	
	local tween = TweenService:Create(circle, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Transparency = 1, Size = Vector3.new(12, 0.2, 12)})
	tween:Play()
	
	task.delay(0.9, function()
		if circle and circle.Parent then
			circle:Destroy()
		end
	end)
end

local function setupJumpDetection()
	for _, conn in pairs(jumpConnections) do
		conn:Disconnect()
	end
	jumpConnections = {}
	
	if humanoid then
		local jumpConn = humanoid.Jumping:Connect(function(active)
			if active and rootPart then
				createJumpCircle(rootPart.Position)
			end
		end)
		table.insert(jumpConnections, jumpConn)
	end
end

